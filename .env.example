# Web 服务配置
WEB_PORT=8001                  # Web服务监听的端口，默认8001，可根据需要修改

DEFAULT_USERNAME=admin         # 默认登录用户名，首次启动时生效
DEFAULT_PASSWORD=ChangeMe_123! # 默认登录密码，首次启动时生效，首次登录后请立即修改

SECRET_KEY=replace-with-a-random-secret # Flask应用的密钥，用于加密session等，必须修改为安全随机字符串

# 日志配置
LOG_LEVEL=INFO                 # 日志级别，可选DEBUG/INFO/WARNING/ERROR/CRITICAL，生产环境建议用INFO或WARNING
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s  # 日志输出格式
LOG_FILE=/var/log/frpc-web/app.log  # 日志文件路径；Docker 中保持默认，本地直接运行会自动映射到 ./logs

# 数据库配置
DATABASE_URL=sqlite:////app/data/frpc.db # 数据库连接地址；Docker 中保持默认，本地直接运行会自动映射到 ./data/frpc.db

# 安全配置
SESSION_COOKIE_SECURE=False        # 是否只通过HTTPS传输session cookie，生产环境建议True
SESSION_COOKIE_HTTPONLY=True       # 是否禁止JS访问session cookie，建议True
REMEMBER_COOKIE_SECURE=False       # 是否只通过HTTPS传输“记住我”cookie，生产环境建议True
REMEMBER_COOKIE_HTTPONLY=True      # 是否禁止JS访问“记住我”cookie，建议True

# 系统与运行参数
TZ=Asia/Shanghai                   # 容器内时区

# 网络健康检查（可选）
NETWORK_CHECK_INTERVAL=1800        # 健康检查间隔（秒）
NETWORK_CHECK_HOSTS=8.8.8.8,114.114.114.114 # 健康检查目标主机列表，逗号分隔
NETWORK_CHECK_TIMEOUT=5            # 健康检查超时（秒）

# FRPC 日志目录（容器内）
FRPC_LOG_DIR=/var/log/frpc-web     # 日志目录；Docker 中保持默认，本地直接运行会自动映射到 ./logs

# FRPS 版本探测（可选）
FRPS_VERSION_URL=                  # 可选：用于读取服务端 frps 版本的 HTTP 地址，可指向自定义版本接口或可解析出版本号的页面
FRPS_VERSION_USERNAME=             # 可选：当 FRPS_VERSION_URL 需要 Basic Auth 时填写用户名
FRPS_VERSION_PASSWORD=             # 可选：当 FRPS_VERSION_URL 需要 Basic Auth 时填写密码
